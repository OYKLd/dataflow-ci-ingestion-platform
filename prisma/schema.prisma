generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UploadStatus {
  PENDING
  PROCESSING
  SUCCESS
  PARTIAL
  FAILED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Source {
  id          String   @id @default(cuid())
  name        String
  description String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  schemas     SchemaVersion[]
  uploads     FileUpload[]
}

model SchemaVersion {
  id        String   @id @default(cuid())

  sourceId  String
  source    Source   @relation(fields: [sourceId], references: [id])

  version   Int
  schema    Json

  createdAt DateTime @default(now())
  updatedAt   DateTime @updatedAt  
}

model FileUpload {
  id          String   @id @default(cuid())

  sourceId    String
  source      Source   @relation(fields: [sourceId], references: [id])

  fileName    String

  status      UploadStatus

  totalRows   Int @default(0)
  validRows   Int @default(0)
  invalidRows Int @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  errors      ValidationError[]
}

model ValidationError {
  id          String   @id @default(cuid())

  uploadId    String
  upload      FileUpload @relation(fields: [uploadId], references: [id])

  rowNumber   Int

  columnName  String

  message     String
}